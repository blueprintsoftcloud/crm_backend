// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  STAFF
}

// Features that Super Admin can toggle on/off for Admin
enum Feature {
  USER_MANAGEMENT
  CATEGORY_MANAGEMENT
  PRODUCT_MANAGEMENT
  ORDER_MANAGEMENT
  COUPON_MANAGEMENT
  NOTIFICATION_MANAGEMENT
  REPORTS_ANALYTICS
  STAFF_MANAGEMENT
  STAFF_PERMISSION_MANAGEMENT
  WAREHOUSE_SETTINGS
  AUDIT_LOG
  CUSTOMER_ACTIVITY_TRACKER
  PAYMENT_LOGS
  PRODUCT_REVIEWS
  HOMEPAGE_MANAGEMENT
  ADMIN_ORDER  // Admin can place orders on behalf of customers (cash sales)
}

enum OrderStatus {
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  POD
  CASH  // Cash collected by admin when placing order on behalf of customer
}

enum NotificationType {
  NEW_ORDER
  ORDER_UPDATE
  PAYMENT_FAILED
  PAYMENT_SUCCESS
  LOW_STOCK
  GENERAL
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  username     String
  email        String?  @unique   // nullable: mobile-OTP customers have no email
  phone        String   @unique   // unique: used as identifier for mobile-OTP login
  password     String?            // nullable: mobile-OTP customers have no password
  role         Role     @default(CUSTOMER)
  isVerified   Boolean  @default(false)
  refreshToken String?  // stored for server-side revocation on logout
  avatar       String?            // Cloudinary URL for profile picture

  addresses     Address[]
  cart          Cart?
  orders        Order[]
  adminPlacedOrders Order[] @relation("AdminPlacedOrders")  // Orders this admin placed on behalf of customers
  wishlist      Wishlist[]
  reviews       Review[]
  notifications Notification[] @relation("RecipientNotifications")
  triggeredNotifications Notification[] @relation("TriggeredNotifications")
  auditLogs     AuditLog[]
  tempUpdate    TempUpdate?

  // Staff relations
  staffProfile StaffProfile? @relation("StaffUser")
  managedStaff StaffProfile[] @relation("StaffManager")
  paymentLogs  PaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// ─── Address ──────────────────────────────────────────────────────────────────
// Fixed: was single address per user (upsert). Now multiple addresses with isDefault flag.

model Address {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @db.ObjectId
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullAddress String
  city        String
  state       String
  zipCode     String
  country     String  @default("India")
  landmark    String?
  isDefault   Boolean @default(false)

  // GeoJSON coordinates for shipping distance calculation
  latitude    Float?
  longitude   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)

  products    Product[]
  attributes  CategoryAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  code          String   @unique
  name          String
  description   String?
  purchasePrice Float?              // Cost price / purchase price
  price         Float               // Selling price (current price)
  stock         Int      @default(0)
  sizes         String[] @default([])    // Available sizes e.g. ["S","M","L"]
  discount      Float    @default(0)     // Discount percentage 0–100
  image       String?         // Primary image URL
  images      String[]        // Additional image URLs
  rating      Float    @default(0)
  numReviews  Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)  // Shown in Featured Collections on homepage
  featuredOrder Int?                    // Sort order within featured section (lower = first)

  categoryId  String @db.ObjectId
  category    Category  @relation(fields: [categoryId], references: [id])

  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlist        Wishlist[]
  reviews         Review[]
  attributeValues ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([price])
  @@index([isActive])
  @@index([isFeatured])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  cartId    String @db.ObjectId
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

// ─── Order ────────────────────────────────────────────────────────────────────
// Fixed: razorpayOrderId is now optional (POD orders don't have one).
// Fixed: shippingAddress is a snapshot (Json) — address doesn't affect old orders if user changes it.
// Added: discountAmount, taxAmount for future coupon/GST support.

model Order {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  userId         String @db.ObjectId
  user           User          @relation(fields: [userId], references: [id])

  items          OrderItem[]

  totalAmount    Float         // Subtotal (products only)
  shippingCharge Float         @default(0)
  discountAmount Float         @default(0)
  taxAmount      Float         @default(0)
  finalAmount    Float         // totalAmount + shippingCharge - discountAmount + taxAmount

  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  orderStatus    OrderStatus   @default(PROCESSING)

  // Razorpay — nullable for POD orders
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Snapshot of delivery address at time of order (immutable)
  shippingAddress Json

  // Coupon applied (optional)
  couponId       String? @db.ObjectId
  coupon         Coupon? @relation(fields: [couponId], references: [id])

  // Admin-placed orders: tracks which admin created this on behalf of the customer
  placedByAdminId String? @db.ObjectId
  placedByAdmin   User?   @relation("AdminPlacedOrders", fields: [placedByAdminId], references: [id])

  notifications  Notification[]
  paymentLogs    PaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderStatus])
  @@index([createdAt])
  @@index([placedByAdminId])
}

model OrderItem {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String @db.ObjectId
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Snapshot of price at time of purchase

  @@index([orderId])
}

// ─── CategoryAttribute ────────────────────────────────────────────────────────
// Defines which filterable/configurable attributes belong to a category.
// e.g. "Sarees" → Fabric (SELECT), Color (MULTISELECT), Length (NUMBER)

model CategoryAttribute {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  categoryId   String @db.ObjectId
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String   // e.g. "Fabric", "RAM", "Color"
  type         String   // "SELECT" | "MULTISELECT" | "TEXT" | "NUMBER" | "BOOLEAN"
  isFilterable Boolean  @default(true)
  isRequired   Boolean  @default(false)
  sortOrder    Int      @default(0)

  values        CategoryAttributeValue[]
  productValues ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
  @@index([categoryId])
}

// ─── CategoryAttributeValue ───────────────────────────────────────────────────
// Predefined pick-list options for SELECT / MULTISELECT attributes.
// e.g. Fabric → Silk | Cotton | Georgette

model CategoryAttributeValue {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  attributeId String @db.ObjectId
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  sortOrder   Int               @default(0)

  productValues ProductAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
}

// ─── ProductAttributeValue ────────────────────────────────────────────────────
// Stores the actual attribute spec for each product.
// SELECT / MULTISELECT → attributeValueId is set; textValue is null.
// TEXT / NUMBER / BOOLEAN → textValue is set; attributeValueId is null.

model ProductAttributeValue {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  productId        String @db.ObjectId
  product          Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId      String @db.ObjectId
  attribute        CategoryAttribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValueId String? @db.ObjectId
  attributeValue   CategoryAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)
  textValue        String?

  @@index([productId])
  @@index([attributeId])
  @@index([attributeValueId])
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────
// Fixed: was stored as array on User document (scalability issue). Now a proper join table.

model Wishlist {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String @db.ObjectId
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int     // 1–5
  comment   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // One review per user per product
  @@index([productId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  message       String
  type          NotificationType
  isRead        Boolean          @default(false)

  orderId       String? @db.ObjectId
  order         Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  triggeredById String? @db.ObjectId          // User who caused the notification
  triggeredBy   User?            @relation("TriggeredNotifications", fields: [triggeredById], references: [id], onDelete: SetNull)
  recipientId   String? @db.ObjectId          // null = broadcast to all admins
  recipient     User?            @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientRole String           @default("admin") // "admin" | "customer"

  createdAt DateTime @default(now())

  @@index([recipientId])
  @@index([recipientRole, isRead])
}

// ─── OTP ──────────────────────────────────────────────────────────────────────
// Replaces MongoDB TTL index — cleanup handled by a setInterval in server.ts

model Otp {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otp       String
  purpose   String   @default("login") // "login" | "signup" | "passwordReset" | "profileUpdate"
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([email, purpose])
}

// ─── TempUpdate ───────────────────────────────────────────────────────────────
// Holds pending profile changes until OTP is verified

model TempUpdate {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pendingData Json     // { username?, phone?, email? }
  otp         String
  expiresAt   DateTime

  createdAt DateTime @default(now())
}

// ─── Coupon ───────────────────────────────────────────────────────────────────
// New feature — was missing entirely in the original codebase

model Coupon {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  code           String   @unique
  description    String?
  discountType   String   // "PERCENTAGE" | "FLAT"
  discountValue  Float
  minOrderAmount Float    @default(0)
  maxUses        Int?     // null = unlimited
  usedCount      Int      @default(0)
  isActive       Boolean  @default(true)
  expiresAt      DateTime?

  orders         Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── StaffProfile ─────────────────────────────────────────────────────────────
// Stores per-staff granular permissions set by the Admin.
// permissions: string[] of StaffPermission constants e.g. ["CATEGORY_VIEW", "PRODUCT_ADD"]

model StaffProfile {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @unique @db.ObjectId
  user        User     @relation("StaffUser", fields: [userId], references: [id], onDelete: Cascade)
  managedBy   String @db.ObjectId
  manager     User     @relation("StaffManager", fields: [managedBy], references: [id])
  permissions String[] // e.g. ["CATEGORY_VIEW", "CATEGORY_EDIT", "PRODUCT_VIEW", ...]
  isActive    Boolean  @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managedBy])
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────
// Tracks admin/super-admin actions for auditability.

model AuditLog {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // e.g. "CREATE_COUPON", "DELETE_USER", "UPDATE_ORDER_STATUS"
  entity    String   // e.g. "Coupon", "User", "Order"
  entityId  String?
  details   Json?    // snapshot / diff data
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── FeatureFlag ──────────────────────────────────────────────────────────────
// Super Admin toggles features on/off for the Admin.
// All features default to enabled; Super Admin can disable any at any time.
// SUPER_ADMIN access is never blocked by feature flags.

model FeatureFlag {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  feature   Feature  @unique
  isEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── AppSetting ───────────────────────────────────────────────────────────────
// Generic key-value store for super-admin-configurable settings.
// Example keys: "WAREHOUSE_LAT", "WAREHOUSE_LNG", "WAREHOUSE_NAME"

model AppSetting {
  key       String @id @default(auto()) @map("_id") @db.ObjectId  // e.g. "WAREHOUSE_LAT"
  value     String         // stored as string, cast at read-time
  updatedAt DateTime @updatedAt
}

// ─── PaymentLog ───────────────────────────────────────────────────────────────
// Immutable record written on every payment lifecycle event.
// Captures Razorpay IDs, raw gateway response, and signature verification result.

model PaymentLog {
  id                String @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String @db.ObjectId
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId            String @db.ObjectId
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Event type: ORDER_CREATED | PAYMENT_SUCCESS | PAYMENT_FAILED | ORDER_POD
  event             String

  // Razorpay identifiers (null for POD orders)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus
  amount            Float
  currency          String        @default("INR")

  // Raw gateway response / verification metadata stored as JSON
  gatewayResponse   Json?
  // null = not applicable (POD), true/false = online signature check result
  signatureValid    Boolean?

  ipAddress         String?

  createdAt         DateTime      @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([paymentStatus])
  @@index([event])
  @@index([createdAt])
}

// ─── HomeBanner ────────────────────────────────────────────────────────────────
// Admin-managed content blocks for the home page.
// type: "DISCOUNT_PANEL" = discount section image panel
//       "CAROUSEL_ITEM"  = curated looks carousel slide
// The DISCOUNT section also has a shared section header stored via AppSetting:
//   HOME_DISCOUNT_TITLE, HOME_DISCOUNT_SUBTITLE

model HomeBanner {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // "DISCOUNT_PANEL" | "CAROUSEL_ITEM"

  // Shared fields
  title       String   // Panel label / carousel caption
  image       String   // Cloudinary URL
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  // DISCOUNT_PANEL only
  discount    String?  // e.g. "20% OFF"
  description String?  // Body text shown on the overlay

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive, sortOrder])
}
