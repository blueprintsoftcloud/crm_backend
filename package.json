{
  "name": "blueprint-crm-api",
  "version": "2.0.0",
  "description": "Blueprint CRM E-Commerce API — TypeScript + PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:legacy": "nodemon src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-all": "tsx prisma/seed-all-users.ts",
    "db:seed-superadmin": "tsx prisma/seed-superadmin.ts",
    "db:migrate-mongo": "tsx prisma/migrate-from-mongo.ts",
    "db:migrate-mongo:dry": "tsx prisma/migrate-from-mongo.ts --dry-run",
    "lint": "eslint src --ext .ts",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-geocoder": "^4.4.1",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/connect": "^3.4.38",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ms": "^2.1.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/node-fetch": "^2.6.13",
    "@types/node-geocoder": "^4.2.6",
    "@types/nodemailer": "^6.4.17",
    "@types/send": "^1.2.1",
    "@types/serve-static": "^2.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prisma": "6.19.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
